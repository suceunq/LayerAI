{
  "name": "layerai",
  "version": "0.1.0",
  "private": true,
  "description": "LayerAI - assistant IA de preparation d'impression 3D pour imprimantes Prusa",
  "license": "UNLICENSED",
  "scripts": {
    "dev": "turbo run dev --filter=@layerai/desktop",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "ingest:profiles": "turbo run ingest --filter=@layerai/profile-ingest",
    "package:win": "turbo run build && pnpm --filter @layerai/desktop package:win"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=20.0.0"
  }
}
