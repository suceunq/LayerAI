    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "tailwindcss": "^4.3.2",
    "tsx": "^4.19.2",
    "typescript": "^5.9.3",
    "vite": "^8.1.3"
